# ─── Frontend (Vite) ──────────────────────────────────────────────
# Copy this to .env.local (git-ignored) and fill in your values.
# Never commit real credentials to git!

# Firebase Web SDK — from Firebase Console → Project Settings → Your apps
VITE_FIREBASE_API_KEY=AIza...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123def456

# ─── Backend (Express / Cloud Run) ────────────────────────────────
# Copy this to artifacts/api-server/.env or set as Cloud Run env vars

# Database: Neon PostgreSQL (https://neon.tech → create a project → copy connection string)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Google Gemini AI (https://aistudio.google.com/apikey)
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.0-flash

# Firebase Admin SDK
# Option A: paste the service account JSON as a single-line string
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"..."}
# Option B: just the project ID (uses Application Default Credentials — works on Cloud Run automatically)
FIREBASE_PROJECT_ID=your-project-id

# Server settings
PORT=5000
NODE_ENV=production

# Job boards API keys
ADZUNA_APP_ID=your-adzuna-app-id
ADZUNA_APP_KEY=your-adzuna-app-key
JOOBLE_API_KEY=your-jooble-api-key
CAREERJET_API_KEY=your-careerjet-api-key
REED_API_KEY=your-reed-api-key
